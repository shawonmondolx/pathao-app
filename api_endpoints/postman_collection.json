  "item": [
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "Login (Issue Token)",
          "event": [{ "listen": "test", "script": { "exec": [
            "var json = pm.response.json();",
            "if (json.data && json.data.token) { pm.collectionVariables.set('token', json.data.token); }"
          ], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "App-Version", "value": "{{app_version}}" },
              { "key": "X-Language", "value": "{{x_language}}" },
              { "key": "X-Country-Id", "value": "{{x_country_id}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"01777884223\",\n  \"password\": \"YourPassword\",\n  \"client_id\": \"1\",\n  \"client_secret\": \"<secret>\",\n  \"grant_type\": \"password\",\n  \"scope\": \"*\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/api/v1/issue-token", "host": ["{{base_url}}"], "path": ["api","v1","issue-token"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "App-Version", "value": "{{app_version}}" },
              { "key": "X-Language", "value": "{{x_language}}" },
              { "key": "X-Country-Id", "value": "{{x_country_id}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/logout", "host": ["{{base_url}}"], "path": ["api","v1","logout"] }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"old_password\": \"current\",\n  \"new_password\": \"newpass\",\n  \"new_password_confirmation\": \"newpass\"\n}", "options": {"raw":{"language":"json"}} },
            "url": { "raw": "{{base_url}}/api/v1/user/reset-password", "host": ["{{base_url}}"], "path": ["api","v1","user","reset-password"] }
          }
        }
      ]
